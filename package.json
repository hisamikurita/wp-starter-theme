{
  "name": "wp-env",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development vite",
    "build": "cross-env NODE_ENV=production vite build",
    "preview": "vite preview",
    "wp-env": "wp-env",
    "db-import": "gzip -d sql/wpenv.sql.gz | npm run wp-env run cli wp db import sql/wpenv.sql",
    "db-export": "npm run wp-env run cli wp db export sql/wpenv.sql; gzip -f sql/wpenv.sql",
    "wp-start": "npm run wp-env start",
    "wp-restart": "npm run wp-env start --update",
    "wp-setup": "npm run wp-start && npm run db-import",
    "wp-destroy": "npm run wp-env destroy"
  },
  "author": "HISAMI KURITA",
  "license": "ISC",
  "devDependencies": {
    "@wordpress/env": "^5.15.0",
    "cross-env": "^7.0.3",
    "postcss": "^8.4.22",
    "sass": "^1.62.0",
    "tailwindcss": "^3.3.1",
    "vite": "^4.2.0",
    "vite-plugin-imagemin": "^0.6.1",
    "vite-plugin-live-reload": "^3.0.2",
    "vite-plugin-static-copy": "^0.14.0"
  }
}
